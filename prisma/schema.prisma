generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  message   String   @db.Text
  createdAt DateTime @default(now())
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  description String   @db.Text
  category    String
  thumbnail   String
  techStack   Json?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TeamMember {
  id          Int      @id @default(autoincrement())
  name        String
  role        String
  bio         String   @db.Text
  image       String?
  socialLinks Json?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  icon        String
  tag         String?
  gradient    String?
  features    Json?
  images      Json?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  logo      String
  website   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Not part of the original spec, but the site's existing /blog page needs a backing
// model or it breaks — kept as a separate concern from Project/Contact/etc.
model Post {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  title     String
  excerpt   String   @db.Text
  body      String?  @db.Text
  category  String
  image     String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id              Int      @id @default(autoincrement())
  title           String
  slug            String   @unique
  department      String?
  location        String
  type            String
  level           String?
  compensation    String?
  description     String   @db.Text
  responsibilities Json?
  requirements    Json?
  images          Json?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  applications    JobApplication[]
}

model JobApplication {
  id        Int      @id @default(autoincrement())
  jobId     Int
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name      String
  email     String
  country   String
  linkedin  String?
  resumeUrl String
  createdAt DateTime @default(now())
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

// Backs the admin dashboard login (Auth.js Credentials provider) — not in the
// original spec either, but required for the admin CRUD screens to stay protected.
model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String?
  image        String?
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
}

// Progressive login-delay counter for the admin login form (lib/login-throttle.js).
// Lives in the DB rather than in-memory because Vercel can route consecutive
// requests to different serverless instances — an in-memory counter doesn't
// reliably survive between two failed attempts from a real attacker (or a
// tester switching browsers), which defeated the whole point of the throttle.
model LoginAttempt {
  email       String   @id
  count       Int      @default(0)
  lastAttempt DateTime
}

// Tracks public site visits (marketing pages only, not /admin) for the visitor
// count shown in the admin dashboard.
model PageView {
  id        Int      @id @default(autoincrement())
  path      String
  createdAt DateTime @default(now())
}
